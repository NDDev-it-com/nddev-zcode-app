# nddev-zcode-app — environment + secrets template
#
# Copy this file to build/.env and edit. build/.env is gitignored and NEVER
# committed. The installer sources it for both the install target directory
# and secret values.
#
#   cp build/.env.example build/.env
#   $EDITOR build/.env
#
# Every value below is OPTIONAL — sensible defaults apply when commented out.

# ─── Install target ──────────────────────────────────────────────────────
# Where the installer builds ~/.zcode. Default is the standard ZCode location.
# Override to install into a custom directory (e.g. testing, multi-account).
# ZCODE_TARGET=$HOME/.zcode

# Where backups are stored. Default is ~/.zcode-backups.
# ZCODE_BACKUPS_DIR=$HOME/.zcode-backups

# ─── Provider secrets (rendered into v2/config.json) ─────────────────────
# Z.ai (GLM) coding-plan provider API key
ZAI_API_KEY=

# Bigmodel coding-plan provider API key (optional; provider is disabled by default)
BIGMODEL_API_KEY=

# ─── MCP server secrets (rendered into mcp.json / cli/config.json) ────────
# GitHub PAT for the github MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Context7 API key for the context7 MCP server
CONTEXT7_API_KEY=

# Add any additional secrets your plugins/MCP servers need below.
