# nddev-zcode-app — secrets template
#
# Copy this file to build/.env and fill in real values. build/.env is gitignored
# and NEVER committed. The installer sources it and substitutes ${VAR} placeholders
# in zcode_tools/*.template.json at install time.
#
#   cp build/.env.example build/.env
#   $EDITOR build/.env
#
# Required for the default provider definitions (v2/config.json):

# Z.ai (GLM) coding-plan provider API key
ZAI_API_KEY=

# Bigmodel coding-plan provider API key (optional; provider is disabled by default)
BIGMODEL_API_KEY=

# Common MCP server secrets (used when you add servers to zcode_tools/mcp.json):

# GitHub PAT for the github MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=

# Context7 API key for the context7 MCP server
CONTEXT7_API_KEY=

# Add any additional secrets your plugins/MCP servers need below.
